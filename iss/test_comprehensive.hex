// ============================================================================
// Test program: test_comprehensive.hex
// All encodings hand-verified against RISC-V spec.
//
// Expected final register state:
//   x1  = 0x00000054  (JAL link: PC+4 of JAL at 0x50)
//   x5  = 0x00000005  x6  = 0x00000003  x7  = 0x00000008
//   x8  = 0x00000002  x9  = 0x00000001  x10 = 0x00000007
//   x11 = 0x00000006  x12 = 0x00000000  x13 = 0x00000001
//   x14 = 0x00000014  x15 = 0x00000001  x16 = 0x12345000
//   x17 = 0x12345678  x18 = 0x00000008  x20 = 0x0000000A
//   x21 = 0x0000000A  x23 = 0x0000002A
// ============================================================================

